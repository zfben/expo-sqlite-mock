  "license": "MIT",
  "homepage": "https://github.com/zfben/expo-sqlite-mock",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zfben/expo-sqlite-mock.git"
  },
  "bugs": {
    "url": "https://github.com/zfben/expo-sqlite-mock/issues"
  },
  "scripts": {
    "test": "jest --coverage --forceExit --testTimeout=10000",
    "lint": "biome check --write"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "testRegex": "/*\\.test\\.tsx?$",
    "maxWorkers": 1,
    "setupFilesAfterEnv": [
      "<rootDir>/src/__tests__/setup.ts"
    ]
  },
  "files": [
    "src/ExpoSQLiteNext.ts",
    "src/setup.ts"
  ],
  "peerDependencies": {
    "better-sqlite3": "*",
    "expo": ">=55",
    "expo-sqlite": "*",
    "jest": "~29"
  },
  "devDependencies": {
    "@biomejs/biome": "*",
    "@testing-library/react-native": "~13",
    "@types/better-sqlite3": "*",
    "@types/jest": "~29",
    "@types/react": "*",
    "better-sqlite3": "*",
    "drizzle-orm": "*",
    "expo": "~55",
    "expo-modules-core": "*",
    "expo-sqlite": "*",
    "jest": "~29",
    "jest-expo": "~55",
    "react": "*",
    "react-native": "~0.80",
    "react-test-renderer": "*",
    "typescript": "*"
  }
}
